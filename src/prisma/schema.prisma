generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Car {
  id               String         @id
  name             String
  make             String
  model            String
  year             Int
  segment          String
  imageUrl         String?
  imageProcessedAt DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  motorisations    Motorisation[]
  carImage         CarImage?
}

model Motorisation {
  id           String   @id
  carId        String
  car          Car      @relation(fields: [carId], references: [id])
  name         String
  engine       String
  power        Int
  fuel         String
  transmission String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CarImage {
  id          String   @id @default(cuid())
  carId       String   @unique
  car         Car      @relation(fields: [carId], references: [id])
  publicUrl   String
  width       Int      @default(1600)
  height      Int      @default(900)
  sourceUrl   String?
  score       Int?
  processedAt DateTime @default(now())
}
